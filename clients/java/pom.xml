<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <groupId>dev.custodia</groupId>
  <artifactId>custodia-client</artifactId>
  <version>0.0.0-private</version>
  <packaging>jar</packaging>

  <name>Custodia Java client</name>
  <description>Java REST/mTLS transport and local client-side crypto helpers for Custodia.</description>
  <url>https://github.com/marcofortina/custodia</url>

  <licenses>
    <license>
      <name>GNU Affero General Public License v3.0 only</name>
      <url>https://www.gnu.org/licenses/agpl-3.0.html</url>
      <distribution>repo</distribution>
    </license>
  </licenses>

  <developers>
    <developer>
      <name>Marco Fortina</name>
    </developer>
  </developers>

  <scm>
    <connection>scm:git:https://github.com/marcofortina/custodia.git</connection>
    <developerConnection>scm:git:ssh://git@github.com/marcofortina/custodia.git</developerConnection>
    <url>https://github.com/marcofortina/custodia</url>
  </scm>

  <properties>
    <maven.compiler.release>17</maven.compiler.release>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
