CUSTODIA_API_ADDR=:8443
CUSTODIA_HEALTH_ADDR=
CUSTODIA_WEB_ADDR=:9443
CUSTODIA_STORE_BACKEND=memory
CUSTODIA_DATABASE_URL=
CUSTODIA_TLS_CERT_FILE=
CUSTODIA_TLS_KEY_FILE=
CUSTODIA_CLIENT_CA_FILE=
CUSTODIA_CLIENT_CRL_FILE=
CUSTODIA_DEV_INSECURE_HTTP=true
CUSTODIA_BOOTSTRAP_CLIENTS=client_alice:client_alice,client_bob:client_bob,admin:admin
CUSTODIA_ADMIN_CLIENT_IDS=admin
CUSTODIA_MAX_ENVELOPES_PER_SECRET=100
CUSTODIA_RATE_LIMIT_BACKEND=memory
CUSTODIA_VALKEY_URL=
CUSTODIA_CLIENT_RATE_LIMIT_PER_SECOND=100
CUSTODIA_GLOBAL_RATE_LIMIT_PER_SECOND=5000
CUSTODIA_IP_RATE_LIMIT_PER_SECOND=1000
CUSTODIA_HTTP_READ_TIMEOUT_SECONDS=15
CUSTODIA_HTTP_WRITE_TIMEOUT_SECONDS=15
CUSTODIA_HTTP_IDLE_TIMEOUT_SECONDS=60
CUSTODIA_SHUTDOWN_TIMEOUT_SECONDS=10

# Dedicated certificate signing service (admin mTLS only in production).
CUSTODIA_SIGNER_ADDR=:9444
CUSTODIA_SIGNER_TLS_CERT_FILE=
CUSTODIA_SIGNER_TLS_KEY_FILE=
CUSTODIA_SIGNER_CLIENT_CA_FILE=
CUSTODIA_SIGNER_CA_CERT_FILE=
CUSTODIA_SIGNER_CA_KEY_FILE=
CUSTODIA_SIGNER_KEY_PROVIDER=file
CUSTODIA_SIGNER_ADMIN_SUBJECTS=signer_admin
CUSTODIA_SIGNER_DEFAULT_TTL_HOURS=24
CUSTODIA_SIGNER_DEV_INSECURE_HTTP=false
CUSTODIA_SIGNER_SHUTDOWN_TIMEOUT_SECONDS=10

# Web console MFA/passkey controls. Web pages remain metadata-only.
CUSTODIA_WEB_MFA_REQUIRED=false
CUSTODIA_WEB_TOTP_SECRET=
CUSTODIA_WEB_SESSION_SECRET=
CUSTODIA_WEB_SESSION_TTL_SECONDS=900
CUSTODIA_WEB_PASSKEY_ENABLED=false
CUSTODIA_WEB_PASSKEY_RP_ID=localhost
CUSTODIA_WEB_PASSKEY_RP_NAME=Custodia
CUSTODIA_WEB_PASSKEY_CHALLENGE_TTL_SECONDS=300
CUSTODIA_SIGNER_AUDIT_LOG_FILE=

# Deployment/HA metadata surfaced in admin status for operational checks.
CUSTODIA_DEPLOYMENT_MODE=single-region
CUSTODIA_DATABASE_HA_TARGET=external
CUSTODIA_AUDIT_SHIPMENT_SINK=
CUSTODIA_SIGNER_CRL_FILE=

CUSTODIA_SIGNER_PKCS11_SIGN_COMMAND=/usr/local/bin/custodia-pkcs11-sign
