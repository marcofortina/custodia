{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "replicaCount": { "type": "integer", "minimum": 1 },
    "revisionHistoryLimit": { "type": "integer", "minimum": 1 },
    "service": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
      }
    },
    "health": {
      "type": "object",
      "properties": {
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
      }
    },
    "config": {
      "type": "object",
      "properties": {
        "maxEnvelopesPerSecret": { "type": "integer", "minimum": 1 },
        "clientRateLimitPerSecond": { "type": "integer", "minimum": 1 },
        "globalRateLimitPerSecond": { "type": "integer", "minimum": 1 },
        "ipRateLimitPerSecond": { "type": "integer", "minimum": 1 }
      }
    },
    "autoscaling": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 1 },
        "maxReplicas": { "type": "integer", "minimum": 1 },
        "targetCPUUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 }
      }
    }
  }
}
