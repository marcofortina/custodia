{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "profile": {
      "type": "string",
      "enum": [
        "lite",
        "full",
        "custom"
      ]
    },
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "revisionHistoryLimit": {
      "type": "integer",
      "minimum": 1
    },
    "service": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      }
    },
    "web": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "exposeOnService": {
          "type": "boolean"
        },
        "mfaSecretName": {
          "type": "string"
        },
        "totpSecretKey": {
          "type": "string"
        },
        "sessionSecretKey": {
          "type": "string"
        }
      }
    },
    "health": {
      "type": "object",
      "properties": {
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "exposeOnService": {
          "type": "boolean"
        }
      }
    },
    "bootstrapJob": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "backoffLimit": {
          "type": "integer",
          "minimum": 0
        },
        "ttlSecondsAfterFinished": {
          "type": "integer",
          "minimum": 0
        },
        "annotations": {
          "type": "object"
        }
      }
    },
    "config": {
      "type": "object",
      "properties": {
        "serverURL": {
          "type": "string"
        },
        "webAddr": {
          "type": "string"
        },
        "databaseURL": {
          "type": "string"
        },
        "signerURL": {
          "type": "string"
        },
        "logFile": {
          "type": "string"
        },
        "bootstrapClients": {
          "type": "string",
          "description": "Comma-separated client_id:mtls_subject mappings used for first-run bootstrap."
        },
        "maxEnvelopesPerSecret": {
          "type": "integer",
          "minimum": 1
        },
        "clientRateLimitPerSecond": {
          "type": "integer",
          "minimum": 1
        },
        "globalRateLimitPerSecond": {
          "type": "integer",
          "minimum": 1
        },
        "ipRateLimitPerSecond": {
          "type": "integer",
          "minimum": 1
        },
        "deploymentMode": {
          "type": "string",
          "minLength": 1
        },
        "databaseHATarget": {
          "type": "string",
          "minLength": 1
        },
        "auditShipmentSink": {
          "type": "string"
        }
      }
    },
    "signer": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "replicaCount": {
          "type": "integer",
          "minimum": 1
        },
        "addr": {
          "type": "string",
          "minLength": 1
        },
        "keyProvider": {
          "type": "string",
          "enum": [
            "file",
            "pkcs11"
          ]
        },
        "defaultTTLHours": {
          "type": "integer",
          "minimum": 1
        },
        "shutdownTimeoutSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "service": {
          "type": "object",
          "properties": {
            "port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            }
          }
        },
        "pkcs11SignCommand": {
          "type": "string"
        },
        "pkcs11SignCommandDelivery": {
          "type": "string",
          "enum": [
            "",
            "custom-image",
            "volume"
          ]
        },
        "extraEnv": {
          "type": "array"
        },
        "extraVolumeMounts": {
          "type": "array"
        },
        "extraVolumes": {
          "type": "array"
        }
      }
    },
    "persistence": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "existingClaim": {
          "type": "string"
        },
        "storageClassName": {
          "type": "string"
        },
        "accessModes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "size": {
          "type": "string"
        },
        "mountPath": {
          "type": "string"
        }
      }
    },
    "autoscaling": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "minReplicas": {
          "type": "integer",
          "minimum": 1
        },
        "maxReplicas": {
          "type": "integer",
          "minimum": 1
        },
        "targetCPUUtilizationPercentage": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        }
      }
    },
    "probes": {
      "type": "object",
      "properties": {
        "readiness": {
          "type": "object",
          "properties": {
            "initialDelaySeconds": {
              "type": "integer",
              "minimum": 1
            },
            "periodSeconds": {
              "type": "integer",
              "minimum": 1
            },
            "timeoutSeconds": {
              "type": "integer",
              "minimum": 1
            },
            "failureThreshold": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "liveness": {
          "type": "object",
          "properties": {
            "initialDelaySeconds": {
              "type": "integer",
              "minimum": 1
            },
            "periodSeconds": {
              "type": "integer",
              "minimum": 1
            },
            "timeoutSeconds": {
              "type": "integer",
              "minimum": 1
            },
            "failureThreshold": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      }
    }
  },
  "$comment": "Copyright (c) 2026 Marco Fortina; SPDX-License-Identifier: AGPL-3.0-only. This file is part of Custodia. See the accompanying LICENSE file for details."
}
