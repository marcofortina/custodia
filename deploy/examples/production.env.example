# Custodia production readiness example.
# Fill every placeholder before using this file with `make production-check`.

CUSTODIA_DEV_INSECURE_HTTP=false
CUSTODIA_STORE_BACKEND=postgres
CUSTODIA_RATE_LIMIT_BACKEND=valkey
CUSTODIA_DATABASE_URL=postgres://custodia:REPLACE_ME@db.example.com:5432/custodia?sslmode=require
CUSTODIA_VALKEY_URL=rediss://valkey.example.com:6379/0

CUSTODIA_TLS_CERT_FILE=/etc/custodia/tls/server.crt
CUSTODIA_TLS_KEY_FILE=/etc/custodia/tls/server.key
CUSTODIA_CLIENT_CA_FILE=/etc/custodia/tls/client-ca.crt
CUSTODIA_CLIENT_CRL_FILE=/etc/custodia/revocation/client.crl.pem
CUSTODIA_ADMIN_CLIENT_IDS=admin

CUSTODIA_WEB_MFA_ENABLED=true
CUSTODIA_WEB_TOTP_SECRET=REPLACE_WITH_BASE32_SECRET
CUSTODIA_WEB_SESSION_SECRET=REPLACE_WITH_32_BYTE_SECRET

CUSTODIA_DEPLOYMENT_MODE=production
CUSTODIA_DATABASE_HA_TARGET=managed-postgres-multi-az
CUSTODIA_AUDIT_SHIPMENT_SINK=s3-object-lock://custodia-audit-prod

CUSTODIA_SIGNER_DEV_INSECURE_HTTP=false
CUSTODIA_SIGNER_ADDR=:9444
CUSTODIA_SIGNER_TLS_CERT_FILE=/etc/custodia-signer/tls/server.crt
CUSTODIA_SIGNER_TLS_KEY_FILE=/etc/custodia-signer/tls/server.key
CUSTODIA_SIGNER_CLIENT_CA_FILE=/etc/custodia-signer/tls/client-ca.crt
CUSTODIA_SIGNER_ADMIN_SUBJECTS=signer_admin
CUSTODIA_SIGNER_KEY_PROVIDER=pkcs11
CUSTODIA_SIGNER_AUDIT_LOG_FILE=/var/log/custodia-signer/audit.jsonl
CUSTODIA_SIGNER_CRL_FILE=/etc/custodia-signer/crl/client.crl.pem

# External production evidence files required for Fort Knox closure gates.
# These point to operator-controlled evidence artifacts, not secret material.
CUSTODIA_EVIDENCE_HSM_ATTESTATION_FILE=/evidence/hsm-attestation.json
CUSTODIA_EVIDENCE_WORM_RETENTION_FILE=/evidence/worm-retention.json
CUSTODIA_EVIDENCE_DATABASE_HA_FILE=/evidence/database-ha.json
CUSTODIA_EVIDENCE_VALKEY_CLUSTER_FILE=/evidence/valkey-cluster.json
CUSTODIA_EVIDENCE_ZERO_TRUST_NETWORK_FILE=/evidence/zero-trust-network.json
CUSTODIA_EVIDENCE_AIR_GAP_BACKUP_FILE=/evidence/air-gap-backup.json
CUSTODIA_EVIDENCE_PEN_TEST_FILE=/evidence/pentest.json
CUSTODIA_EVIDENCE_FORMAL_VERIFICATION_FILE=/evidence/formal-verification.json
CUSTODIA_EVIDENCE_REVOCATION_DRILL_FILE=/evidence/revocation-drill.json
CUSTODIA_EVIDENCE_RELEASE_CHECK_FILE=/evidence/release-check.json
